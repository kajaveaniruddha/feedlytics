# ==============================================
# FEEDLYTICS - DEVELOPMENT ENVIRONMENT
# ==============================================
# Copy this file to .env.development for local development
# All services will use localhost URLs and development settings

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# Local PostgreSQL database
DATABASE_URL=postgresql://postgres:password@localhost:5432/feedlytics_dev

# ==============================================
# REDIS CONFIGURATION
# ==============================================
# Local Redis instance
REDIS_URL=redis://localhost:6379

# ==============================================
# AUTHENTICATION & SECURITY
# ==============================================
# Development NextAuth secret (use a simple string for dev)
NEXTAUTH_SECRET=development-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (use development app)
GITHUB_ID=your-github-dev-client-id
GITHUB_SECRET=your-github-dev-client-secret

# Google OAuth (use development app)
AUTH_GOOGLE_ID=your-google-dev-client-id
AUTH_GOOGLE_SECRET=your-google-dev-client-secret

# ==============================================
# STRIPE PAYMENT INTEGRATION (TEST MODE)
# ==============================================
# Use Stripe test keys for development
STRIPE_SECRET_KEY=sk_test_your-stripe-test-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-test-publishable-key
STRIPE_PRICE_ID=price_your-stripe-test-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-test-webhook-secret

# ==============================================
# EMAIL SERVICE (Gmail SMTP)
# ==============================================
# Use a test Gmail account for development
GOOGLE_MAIL_FROM=your-test-email@gmail.com
GOOGLE_APP_PASSWORD=your-gmail-app-password

# ==============================================
# AI/LLM SERVICE (Groq)
# ==============================================
# Groq API key for development
GROQ_API_KEY=your-groq-api-key

# ==============================================
# SERVICE CONFIGURATION
# ==============================================
# Local services
SERVICES_URL=http://localhost:3001
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ==============================================
# WIDGET CONFIGURATION
# ==============================================
# Local widget URL
VITE_DASHBOARD_BASE_URL=http://localhost:3000

