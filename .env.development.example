# =============================================================================
# Feedlytics — local development template
# =============================================================================
# Copy to `.env.development` and fill in real values:
#   cp .env.development.example .env.development
# =============================================================================

GROQ_API_KEY=your-groq-api-key
GOOGLE_MAIL_FROM=your-email@gmail.com
GOOGLE_APP_PASSWORD=your-gmail-app-password

REDIS_URL=redis://default:redispass@127.0.0.1:6379

STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_replace_me
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_replace_me
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly_replace_me
STRIPE_PRICE_BUSINESS_YEARLY=price_business_yearly_replace_me

SPRING_DATASOURCE_URL=jdbc:postgresql://HOST/DATABASE?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

JWT_SECRET=change-me-at-least-32-characters-long
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=2592000

GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
APP_COOKIE_DOMAIN=
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax

GRPC_CLIENT_FEEDLYTICSQUEUE_ADDRESS=static://127.0.0.1:9090
FEEDLYTICS_INTERNAL_AUTH_TOKEN=dev-internal-auth-change-me
FEEDLYTICS_QUEUE_CALLBACK_BASE_URL=http://localhost:8081

NEXT_PUBLIC_API_BASE_URL=http://localhost:8081
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_ENABLE_MSW=false

PORT=3001
GRPC_PORT=9090
NODE_ENV=development
LOG_LEVEL=info
DASHBOARD_BASE_URL=http://localhost:3000

VITE_FEEDLYTICS_API_BASE_URL=http://localhost:8081
VITE_DEV_WORKSPACE_PUBLIC_ID=
VITE_DEV_WIDGET_SECRET=
