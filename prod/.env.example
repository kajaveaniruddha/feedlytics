# =============================================================================
# Production secrets — VPS layout
# =============================================================================
# On the VPS, prod/ contains ONLY this file (create manually on the server):
#
#   feedlytics/
#   ├── docker-compose.yml
#   └── prod/
#       └── .env                 ← secrets only (never commit, never CI-sync)
#
# Local setup:
#   cp prod/.env.example prod/.env
#
# nginx configs:  prod/nginx/   (local only, gitignored — copy once to /etc/nginx on VPS)
# Image builds:   scripts/build-and-push.sh  (run from your machine / CI)
# =============================================================================

DOCKER_USERNAME=your-dockerhub-username

GROQ_API_KEY=your-groq-api-key
GOOGLE_MAIL_FROM=your-email@gmail.com
GOOGLE_APP_PASSWORD=your-gmail-app-password

REDIS_URL=redis://default:redispass@redis:6379
REDIS_PASSWORD=redispass

GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret
AUTH_GOOGLE_ID=your-google-oauth-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_replace_me
STRIPE_SECRET_KEY=sk_live_or_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_replace_me
STRIPE_PRICE_PRO_YEARLY=price_pro_yearly_replace_me
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly_replace_me
STRIPE_PRICE_BUSINESS_YEARLY=price_business_yearly_replace_me

SPRING_DATASOURCE_URL=jdbc:postgresql://HOST/DATABASE?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

JWT_SECRET=change-me-at-least-32-characters-long
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=2592000

GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

APP_CORS_ALLOWED_ORIGINS="https://feedlytics.in,https://www.feedlytics.in"
APP_COOKIE_DOMAIN=.feedlytics.in
APP_COOKIE_SECURE=true
APP_COOKIE_SAME_SITE=Lax

GRPC_CLIENT_FEEDLYTICSQUEUE_ADDRESS=static://feedlytics-queue-service:9090
FEEDLYTICS_INTERNAL_AUTH_TOKEN=change-me-internal-auth-token
FEEDLYTICS_QUEUE_CALLBACK_BASE_URL=http://feedlytics-service:8081

NEXT_PUBLIC_API_BASE_URL=https://api.feedlytics.in
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
NEXT_PUBLIC_ENABLE_MSW=false

PORT=3001
GRPC_PORT=9090
NODE_ENV=production
LOG_LEVEL=info
DASHBOARD_BASE_URL=https://feedlytics.in

VITE_FEEDLYTICS_API_BASE_URL=https://api.feedlytics.in
